# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/pratipal
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pratipal?retryWrites=true&w=majority

# JWT Authentication
AUTH_JWT_SECRET=your-secret-key-change-this-in-production
JWT_SECRET=your-secret-key-change-this-in-production

# Cloudflare R2 Storage (preferred for image uploads)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://your-custom-domain.com
# Alternative: R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# AWS S3 (fallback for media uploads if R2 not configured)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Razorpay (for payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
ADMIN_EMAIL=admin@yourdomain.com

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development

# Production settings (for Vercel deployment)
# NEXT_PUBLIC_APP_URL=https://pratipal.vercel.app
# NEXT_PUBLIC_API_URL=https://pratipal.vercel.app
# NODE_ENV=production

# Alternative production domain (if using custom domain)
# NEXT_PUBLIC_APP_URL=https://www.pratipal.in
# NEXT_PUBLIC_API_URL=https://www.pratipal.in
# NODE_ENV=production

# Legacy Supabase (can be removed after migration)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=

# Trustpilot (optional — shows TrustBox widget on homepage when set)
# Find your Business Unit ID at: https://businessapp.b2b.trustpilot.com/ → Integrations → TrustBox
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_ID=your-trustpilot-business-unit-id
